# Test-stack config — consumed by the `api` service (env_file) in
# docker-compose.test.yaml. Dummy values only: this stack is disposable and
# never touches production data. Hosts are docker service names, because the
# backend runs INSIDE the compose network (postgres/redis/minio, not localhost).
#
# Every field in backend/app/core/config.py:Settings is set below (required
# fields plus the ones that have defaults) so startup never depends on an
# outside .env.

# --- Postgres (asyncpg) ---
DATABASE_URL=postgresql+asyncpg://argo_test:argo_test@postgres:5432/argo_test

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- MinIO (S3-compatible) ---
MINIO_ENDPOINT=http://minio:9000
# In this stack the "browser" (httpx test client) also runs inside the compose
# network, so presigned URLs must resolve to the service name, not localhost.
MINIO_PUBLIC_ENDPOINT=http://minio:9000
MINIO_ROOT_USER=argo_test
MINIO_ROOT_PASSWORD=argo_test_secret
MINIO_BUCKET_MEDIA=chat-media
MINIO_BUCKET_KB=kb-media
MEDIA_MAX_UPLOAD_BYTES=5368709120
MEDIA_MAX_AUDIO_BYTES=209715200

# --- JWT ---
JWT_SECRET=test_secret_not_for_production_use_only_0123456789abcdef
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30

# --- Dynamics (homework counting start) ---
JOURNAL_PROGRAM_START=2026-07-03

# --- Tasks ---
TASK_DEADLINE_SOON_DAYS=2

# --- Rate limiting (off for tests) ---
RATE_LIMIT_ENABLED=false
RATE_LIMIT_LOGIN_PER_MINUTE=10
RATE_LIMIT_SEND_PER_MINUTE=60
RATE_LIMIT_UPLOAD_PER_MINUTE=30
