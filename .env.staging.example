# Шаблон .env для ТЕСТОВОГО СТЕНДА (staging). Скопировать в .env стенда на сервере
# (/opt/platform-staging/.env) и заполнить. НИКОГДА не коммитить реальный .env.
#
# Стенд полностью изолирован от прода: отдельный compose-проект platform-staging со
# своими volume'ами. Значения секретов ДОЛЖНЫ отличаться от прод-.env (особенно
# JWT_SECRET — иначе токен стенда стал бы валиден на проде).

# --- Postgres (свой инстанс стенда, отдельный volume platform-staging_postgres_data) ---
POSTGRES_USER=app
POSTGRES_PASSWORD=change_me_staging
POSTGRES_DB=platform
DATABASE_URL=postgresql+asyncpg://app:change_me_staging@postgres:5432/platform

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- MinIO (свой инстанс стенда) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_staging_too
MINIO_ENDPOINT=http://minio:9000
# Публичный адрес MinIO для браузера (presigned URL). Стенд за nginx на ПОРТУ 8443,
# path-style по префиксу бакета. Порт :8443 ОБЯЗАТЕЛЕН в значении — backend подписывает
# URL с портом, nginx проксирует Host $http_host, иначе MinIO даст SignatureDoesNotMatch.
MINIO_PUBLIC_ENDPOINT=https://staging.argonautica-systems.ru:8443
MINIO_BUCKET_MEDIA=chat-media
MINIO_BUCKET_KB=kb-media
MEDIA_MAX_UPLOAD_BYTES=5368709120

# --- JWT (свой секрет стенда: openssl rand -hex 32) ---
JWT_SECRET=replace_with_DIFFERENT_long_random_secret
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30

# --- nginx стенда (поддомен staging.*; DOMAIN == MEDIA_DOMAIN) ---
# DOMAIN = server_name стенда И имя файла TLS-серта (${DOMAIN}.crt/.key в
# docker/nginx-staging/certs/) И Host в presigned-подписи. На поддомене — боевой LE
# (docker/nginx-staging/renew-cert.sh). Для IP-режима bootstrap'а — make-self-signed.sh.
DOMAIN=staging.argonautica-systems.ru
MEDIA_DOMAIN=staging.argonautica-systems.ru
UVICORN_WORKERS=2

# --- Telegram-бот: на стенде НЕ поднимается (сервиса bot нет в staging-compose). ---
# Оставить ПУСТЫМ: второй long-polling с прод-токеном сломал бы прод-бота.
TELEGRAM_BOT_TOKEN=
PLATFORM_URL=https://staging.argonautica-systems.ru:8443
TELEGRAM_PROXY=
TELEGRAM_ADMIN_CHAT_ID=
