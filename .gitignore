# Секреты — реальные .env с значениями НИКОГДА не коммитим.
.env
*.env
# ...но шаблон .env.example (без значений) — наоборот, должен быть в git.
!.env.example

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Node / frontend
node_modules/
dist/
.vite/
*.local

# OS / IDE
.DS_Store
.idea/
.vscode/
.claude/

# TLS-серты (self-signed локально / боевые на сервере) — никогда в git.
docker/nginx/certs/
docker/nginx-staging/certs/
# Basic-Auth пароли тестового стенда — секрет, генерится на сервере при bootstrap.
docker/nginx-staging/staging.htpasswd

# dev.sh — PID-файлы и логи локального окружения
.dev/

# Массовое заведение аккаунтов — выгрузка логинов/паролей (секреты) и список ников.
credentials_*.txt
users.md
