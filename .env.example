# Скопировать в .env и заполнить. .env в .gitignore — НИКОГДА не коммитить.

# --- Postgres ---
POSTGRES_USER=app
POSTGRES_PASSWORD=change_me
POSTGRES_DB=platform
# Хост = имя сервиса в docker-сети. Если backend запущен на хосте против контейнеров,
# заменить postgres -> localhost.
DATABASE_URL=postgresql+asyncpg://app:change_me@postgres:5432/platform

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- MinIO (S3-совместимо) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_too
MINIO_ENDPOINT=http://minio:9000
# Адрес MinIO, доступный браузеру (для presigned URL). Внутри docker — minio:9000,
# но клиент-браузер ходит на host. В dev — localhost:9000. Если пусто, берётся MINIO_ENDPOINT.
# В ПРОДЕ presigned-URL подписываются под публичным медиа-доменом за nginx:
#   MINIO_PUBLIC_ENDPOINT=https://${MEDIA_DOMAIN}
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_BUCKET_MEDIA=chat-media
MINIO_BUCKET_KB=kb-media
# Максимальный размер загружаемого файла в байтах (по умолчанию 100 МБ).
MEDIA_MAX_UPLOAD_BYTES=104857600

# --- JWT ---
# Сгенерировать длинный случайный секрет, напр.: openssl rand -hex 32
JWT_SECRET=replace_with_long_random_secret
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30

# --- Деплой / nginx (prod) ---
# Основной домен (SPA + /api + /ws) и медиа-домен (presigned MinIO за nginx).
# Локальная проверка прод-стека: DOMAIN=localhost, MEDIA_DOMAIN=media.localhost.
# В проде — реальные домены (под них же выписываются TLS-серты).
DOMAIN=localhost
MEDIA_DOMAIN=media.localhost
# Число uvicorn-воркеров в контейнере backend (realtime поверх Redis pub/sub — безопасно).
UVICORN_WORKERS=2

# --- Telegram-бот выдачи доступа (scripts/telegram_bot.py, HTTP Bot API) ---
# Токен бота от @BotFather. Если пусто — сервис bot просто не поднимать.
TELEGRAM_BOT_TOKEN=
# Публичный адрес платформы (в сообщениях бота и инструкции по установке PWA).
PLATFORM_URL=https://platform.argonautica-systems.ru
# Прокси для доступа к Telegram, если IP Telegram заблокированы на сервере (частый
# случай на RU-хостинге). Формат: socks5://user:pass@host:port или http://host:port.
# Пусто — прямое подключение.
TELEGRAM_PROXY=
